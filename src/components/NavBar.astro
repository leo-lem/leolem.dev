---
import Icon from "./Icon.astro";
import Thumbnail from "./Thumbnail.astro";
import { aboutMe } from "../content";

const { socials, subscribe = true } = Astro.props as {
  socials: string[];
  subscribe?: boolean;
};

import { getImage } from "astro:assets";
import headerLight from "../assets/header-light.png";
import headerDark from "../assets/header-dark.png";
const light = await getImage({ src: headerLight, width: 1200 });
const dark = await getImage({ src: headerDark, width: 1200 });
---

<header class="sticky top-0 py-3 z-10 stack-sm bg-noise">
  <nav
    class="relative w-full container-wide mx-auto flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4"
    data-testid="nav"
  >
    <div
      class="absolute -inset-y-3 inset-x-0 -z-10 rounded-b-xl overflow-hidden"
    >
      <picture id="header" class="block w-full h-full">
        <source srcset={dark.src} media="(prefers-color-scheme: dark)" />
        <img
          src={light.src}
          alt=""
          width="1200"
          height="400"
          class="w-full h-full object-cover"
        />
      </picture>
    </div>

    <div class="w-full flex items-start justify-between gap-4">
      <div class="flex items-end sm:items-center gap-3">
        <Thumbnail
          src="profile"
          alt="Profile picture of Leopold Lemmermann"
          class="w-24 h-24 aspect-square rounded-full object-cover shadow-[0_8px_20px_rgba(0,0,0,0.6)]"
          loading="eager"
        />

        <a
          href="/"
          class="flex flex-col navigation animate-slidefadein hover:text-accent"
        >
          <span class="font-semibold text-xl sm:text-4xl text-nowrap">
            Leopold Lemmermann
          </span>
          <span class="text-sm sm:text-lg whitespace-nowrap">
            {aboutMe.titles.join(" · ")}
          </span>
        </a>
      </div>

      <div class="absolute top-0 right-0 px-3 flex items-center gap-3 shrink-0">
        {
          socials.map((url: string) => (
            <Icon
              name={url}
              class="icon-sm animate-slidefadein text-accent-solid"
            />
          ))
        }
      </div>
    </div>
  </nav>
</header>

<style>
  @reference "tailwindcss";

  header {
    @apply shadow-(--shadow-color);
    color: var(--text-color);
    background-color: var(--base-color);
    border-color: var(--border-color);
  }

  header a.active {
    @apply font-bold underline;
  }
</style>
