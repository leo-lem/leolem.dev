{
	"image": "mcr.microsoft.com/devcontainers/typescript-node:latest",
	"postCreateCommand": "npm install -g npm@latest && npm install && npx playwright install",
	"postStartCommand": "npm start",
	"customizations": {
		"vscode": {
			"extensions": [
				"astro-build.astro-vscode",
				"bradlc.vscode-tailwindcss",
				"ms-playwright.playwright",
				"GitHub.vscode-pull-request-github"
			]
		}
	},
	"features": {
		"ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
		"ghcr.io/postfinance/devcontainer-features/playwright-deps:1.0.0": {
			"installChromiumDeps": true,
			"installFirefoxDeps": true,
			"installWebkitDeps": true
		}
	},
	"mounts": [
		"source=claude-code-config,target=/home/vscode/.claude,type=volume"
	],
	"runArgs": [
		"-p",
		"4321:4321"
	],
	"portsAttributes": {
		"4321": {
			"label": "Astro",
			"onAutoForward": "openPreview"
		}
	}
}