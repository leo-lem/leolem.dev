{
  "name": "leolem.dev",
  "type": "module",
  "version": "2.2",
  "scripts": {
    "start": "astro dev --host",
    "build": "astro build",
    "test": "playwright test",
    "test:smoke": "npm test -- test/smoke.spec.ts",
    "test:tool": "npm test -- -c playwright.tool.config.ts",
    "test:co2": "tsx test/check_co2.ts",
    "tool:sync": "tsx tool/sync.ts",
    "tool:icons": "tsx tool/icons.ts",
